# ---- Application ----
APP_NAME=UPRVUNL CODSP Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_USER=codsp_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=codsp_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full SQLAlchemy URL (used by the app). Must stay in sync with the values above
# when running via docker-compose (host="db"); use host="localhost" when running
# the API directly on your machine against the dockerized database.
DATABASE_URL=postgresql+psycopg://codsp_user:change_me@localhost:5432/codsp_db

# ---- File Storage (Version 1: local filesystem) ----
DOCUMENT_STORAGE_PATH=./storage/documents

# ---- Daily Stock Validation ----
STOCK_RECONCILIATION_TOLERANCE_MT=0.01

# ---- Optimization ----
OPTIMIZATION_FALLBACK_LANDED_COST=0
OPTIMIZATION_MARKET_TOPUP_MULTIPLIER=1.20
OPTIMIZATION_DEMAND_HORIZON_DAYS=30

# ---- UPSLDC Scheduler ----
UPSLDC_SOURCE_URL=https://upsldc.org/variable-cost
UPSLDC_MAX_PDFS_PER_RUN=10
SCHEDULER_ENABLED=false
SCHEDULER_CRON_HOUR=6
SCHEDULER_CRON_MINUTE=0
